// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admins        Admin[]
  contributions Contribution[]
  payments      Payment[]
  notes         Note[] @relation("NoteCreator")

  @@map("users")
}

model Budgie {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admins       Admin[]
  months       Month[]
  expenses     Expense[]
  contributors Contributor[]

  @@map("budgies")
}

model Admin {
  id        String   @id @default(uuid())
  budgieId  String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budgie Budgie @relation(fields: [budgieId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([budgieId, userId])
  @@map("admins")
}

model Month {
  id        String   @id @default(uuid())
  budgieId  String
  year      Int
  month     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budgie Budgie       @relation(fields: [budgieId], references: [id], onDelete: Cascade)
  costs  Cost[]
  notes  Note[]

  @@unique([budgieId, year, month])
  @@map("months")
}

model Expense {
  id        String   @id @default(uuid())
  budgieId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budgie  Budgie  @relation(fields: [budgieId], references: [id], onDelete: Cascade)
  costs   Cost[]

  @@map("expenses")
}

model Cost {
  id        String   @id @default(uuid())
  monthId   String
  expenseId String
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  month      Month         @relation(fields: [monthId], references: [id], onDelete: Cascade)
  expense    Expense       @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  contributions Contribution[]

  @@unique([monthId, expenseId])
  @@map("costs")
}

model Contributor {
  id        String   @id @default(uuid())
  budgieId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budgie        Budgie         @relation(fields: [budgieId], references: [id], onDelete: Cascade)
  contributions Contribution[]

  @@map("contributors")
}

model Contribution {
  id             String   @id @default(uuid())
  costId         String
  userId         String?
  contributorId  String?
  percentage     Decimal  @db.Decimal(5, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cost        Cost        @relation(fields: [costId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributor Contributor? @relation(fields: [contributorId], references: [id], onDelete: Cascade)
  payments    Payment[]

  @@unique([costId, userId])
  @@unique([costId, contributorId])
  @@map("contributions")
}

model Destination {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]

  @@map("destinations")
}

model Payment {
  id             String   @id @default(uuid())
  destinationId  String
  contributionId String
  userId         String
  status         Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  destination  Destination  @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  contribution Contribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Note {
  id         String   @id @default(uuid())
  monthId    String
  createdById String
  content    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  month      Month @relation(fields: [monthId], references: [id], onDelete: Cascade)
  createdBy  User  @relation("NoteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@map("notes")
}
