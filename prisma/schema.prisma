// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  email     String
  name      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contributors     Contributor[]
  notes            Note[]       @relation("NoteCreator")
  invitationsSent  Invitation[] @relation("InvitationInvitedBy")

  @@map("users")
}

model Budgie {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  months       Month[]
  expenses     Expense[]
  contributors Contributor[]
  invitations  Invitation[]
  destinations Destination[]
  categories   Category[]

  @@map("budgies")
}

model Month {
  id        String   @id @default(uuid())
  budgieId  String
  date      DateTime @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budgie Budgie       @relation(fields: [budgieId], references: [id], onDelete: Cascade)
  costs  Cost[]
  notes  Note[]

  @@unique([budgieId, date])
  @@map("months")
}

model Expense {
  id         String    @id @default(uuid())
  budgieId   String
  name       String
  archived   Boolean   @default(false)
  archivedOn DateTime? @db.Date
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  budgie  Budgie  @relation(fields: [budgieId], references: [id], onDelete: Cascade)
  costs   Cost[]

  @@map("expenses")
}

model Cost {
  id            String   @id @default(uuid())
  monthId       String
  expenseId     String
  destinationId String?
  amount        Decimal  @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  month          Month          @relation(fields: [monthId], references: [id], onDelete: Cascade)
  expense        Expense        @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  destination    Destination?   @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  contributions  Contribution[]
  paymentStatus  PaymentStatus?
  costCategories CostCategory[]

  @@unique([monthId, expenseId])
  @@map("costs")
}

model Category {
  id        String   @id @default(uuid())
  budgieId  String
  name      String
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budgie         Budgie         @relation(fields: [budgieId], references: [id], onDelete: Cascade)
  costCategories CostCategory[]

  @@map("categories")
}

model CostCategory {
  costId     String
  categoryId String
  createdAt  DateTime @default(now())

  cost     Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([costId, categoryId])
  @@map("cost_categories")
}

model Contributor {
  id        String   @id @default(uuid())
  budgieId  String
  name      String
  isAdmin   Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budgie        Budgie         @relation(fields: [budgieId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions Contribution[]

  @@map("contributors")
}

model Contribution {
  id             String   @id @default(uuid())
  costId         String
  contributorId  String
  amount         Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cost        Cost        @relation(fields: [costId], references: [id], onDelete: Cascade)
  contributor Contributor @relation(fields: [contributorId], references: [id], onDelete: Cascade)
  payments    Payment[]

  @@unique([costId, contributorId])
  @@map("contributions")
}

model Destination {
  id            String   @id @default(uuid())
  budgieId      String
  name          String
  recipientName String
  type          String
  iban          String?
  swift         String?
  phone         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  budgie  Budgie  @relation(fields: [budgieId], references: [id], onDelete: Cascade)
  costs   Cost[]
  payments Payment[]

  @@map("destinations")
}

model Payment {
  id             String   @id @default(uuid())
  destinationId  String
  contributionId String
  status         Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  destination  Destination  @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  contribution Contribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model PaymentStatus {
  id        String   @id @default(uuid())
  costId    String   @unique
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cost Cost @relation(fields: [costId], references: [id], onDelete: Cascade)

  @@map("payment_status")
}

model Note {
  id         String   @id @default(uuid())
  monthId    String
  createdById String
  content    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  month      Month @relation(fields: [monthId], references: [id], onDelete: Cascade)
  createdBy  User  @relation("NoteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@map("notes")
}

model Invitation {
  id               String   @id @default(uuid())
  email            String
  invitedById     String
  budgieId        String
  accepted        Boolean  @default(false)
  resolved        Boolean  @default(false)
  tokenHash       String   @unique
  expiresAt       DateTime
  invitationMessage String  @default("") @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budgie   Budgie @relation(fields: [budgieId], references: [id], onDelete: Cascade)
  invitedBy User  @relation("InvitationInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@map("invitations")
}
