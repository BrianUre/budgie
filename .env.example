# Database
# Set these db ones in .env instead
# Budgie uses host port 54320 to avoid conflict with default Postgres (5432).
POSTGRES_USER=budgie
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=budgie
DATABASE_URL="postgresql://budgie:your_secure_password@localhost:54320/budgie?schema=public"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# App URL (for tRPC)
NEXT_PUBLIC_APP_URL=http://localhost:3000